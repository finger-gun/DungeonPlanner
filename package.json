{
  "name": "dungeonplanner-workspace",
  "private": true,
  "version": "0.0.0",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "app": "node scripts/run-vite-package.mjs app dev",
    "app:start": "pnpm run app:dev:full",
    "app:build": "pnpm --filter dungeonplanner-app build",
    "app:lint": "pnpm --filter dungeonplanner-app lint",
    "app:setup": "node scripts/setup-authenticated-app.mjs",
    "app:convex": "pnpm --filter dungeonplanner-app convex:dev",
    "app:convex:codegen": "pnpm --filter dungeonplanner-app convex:codegen",
    "app:convex:up": "pnpm --filter dungeonplanner-app convex:self-hosted:up",
    "app:convex:down": "pnpm --filter dungeonplanner-app convex:self-hosted:down",
    "app:convex:admin-key": "pnpm --filter dungeonplanner-app convex:self-hosted:admin-key",
    "app:convex:auth-keys": "pnpm --filter dungeonplanner-app convex:auth:keys",
    "app:seed": "node scripts/seed-authenticated-app.mjs",
    "app:dev:full": "pnpm run app:convex:up && concurrently -n convex,app -c magenta,blue \"pnpm run app:convex\" \"pnpm run app\"",
    "predev": "pnpm run sync:ktx2-transcoders",
    "prebuild:demo": "pnpm run sync:ktx2-transcoders",
    "pregenerate:thumbnails": "pnpm run sync:ktx2-transcoders",
    "dev": "node scripts/run-vite-package.mjs editor dev",
    "dev:full": "concurrently -n editor,server -c blue,green \"pnpm run dev\" \"pnpm run server\"",
    "build": "pnpm run build:demo && pnpm run build:docs",
    "build:demo": "pnpm --filter dungeonplanner-editor build",
    "build:docs": "node scripts/build-docs-site.mjs",
    "build:all": "turbo run build",
    "docs:build": "pnpm run build:docs",
    "lint": "pnpm --filter dungeonplanner-editor lint && pnpm --filter dungeonplanner-app lint",
    "lint:all": "turbo run lint",
    "preview": "node scripts/run-vite-package.mjs editor preview",
    "character-generator": "node scripts/run-character-generator.mjs",
    "generate:content-pack:core": "node scripts/generate-core-pack.mjs",
    "generate:characters": "node scripts/run-character-generator.mjs",
    "generate:thumbnails": "node scripts/generate-thumbnails.mjs",
    "sync:ktx2-transcoders": "node scripts/sync-ktx2-transcoders.mjs",
    "optimize:models": "node scripts/optimize-models.mjs",
    "import:models": "node scripts/import-models.mjs",
    "test": "vitest run --config vitest.config.ts && pnpm --filter dungeonplanner-editor test && pnpm --filter dungeonplanner-app test",
    "test:all": "turbo run test",
    "test:watch": "pnpm --filter dungeonplanner-editor test:watch",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "verify": "pnpm run lint && pnpm run test && pnpm run build && pnpm run test:e2e",
    "server": "pnpm --filter dungeonplanner-server dev",
    "server:build": "pnpm --filter dungeonplanner-server build",
    "server:start": "pnpm --filter dungeonplanner-server start",
    "turbo": "turbo",
    "video-to-gif": "bash scripts/video-to-gif.sh"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.2.1",
    "sharp": "^0.34.5",
    "turbo": "^2.6.0",
    "vitest": "^4.1.3"
  }
}
